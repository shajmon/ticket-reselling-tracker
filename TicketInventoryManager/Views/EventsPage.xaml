<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TicketInventoryManager.ViewModels"
             xmlns:dto="clr-namespace:TicketInventoryManager.Models.Entities"
             x:DataType="vm:EventsViewModel"
             x:Class="TicketInventoryManager.Views.EventsPage"
             Title="Events">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <Button Text="Add new" Command="{Binding NewEventCommand}" />

            <CollectionView ItemsSource="{Binding Events}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedEvent, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:EventDTO">
                        <VerticalStackLayout Padding="8" Spacing="4">

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding Name}" FontAttributes="Bold" />
                                <Label Text="{Binding EventType}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="8">
                                <Label Text="{Binding VenueName}" />
                                <Label Text="·" />
                                <Label Text="{Binding City}" />
                                <Label Text="{Binding Country, StringFormat='({0})'}" />
                            </HorizontalStackLayout>

                            <Label Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}" />

                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
