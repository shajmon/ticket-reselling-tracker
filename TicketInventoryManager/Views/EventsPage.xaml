<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TicketInventoryManager.ViewModels"
             xmlns:dto="clr-namespace:TicketInventoryManager.Models.Entities"
             x:DataType="vm:EventsViewModel"
             x:Class="TicketInventoryManager.Views.EventsPage"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource AppSurfaceRaised}" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16" MaximumWidthRequest="1000">

            <!-- Header -->
            <Grid ColumnDefinitions="*, Auto">
                <Label Grid.Column="0"
                       Text="Events"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource AppTextPrimary}"
                       VerticalOptions="Center" />
                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Button Text="Dashboard"
                            Command="{Binding GoToDashboardCommand}"
                            Style="{StaticResource GhostButton}" />
                    <Button Text="Export"
                            Command="{Binding ExportEventsCommand}"
                            Style="{StaticResource ChipButton}" />
                    <Button Text="Import"
                            Command="{Binding ImportEventsCommand}"
                            Style="{StaticResource ChipButton}" />
                    <Button Text="+ Add"
                            Command="{Binding NewEventCommand}"
                            FontSize="13"
                            Padding="12,6"
                            CornerRadius="6" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Event list -->
            <CollectionView ItemsSource="{Binding Events}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedEvent, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:EventDTO">
                        <Border BackgroundColor="{StaticResource AppSurface}"
                                Stroke="{StaticResource AppBorder}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="16,14"
                                Margin="0,0,0,8">
                            <Grid RowDefinitions="Auto, Auto" RowSpacing="6">

                                <Grid Grid.Row="0" ColumnDefinitions="*, Auto">
                                    <Label Grid.Column="0"
                                           Text="{Binding Name}"
                                           FontAttributes="Bold"
                                           FontSize="15"
                                           TextColor="{StaticResource AppTextPrimary}" />
                                    <Label Grid.Column="1"
                                           Text="{Binding EventType}"
                                           FontSize="11"
                                           TextColor="{StaticResource AppTextMuted}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <HorizontalStackLayout Grid.Row="1" Spacing="6">
                                    <Label Text="{Binding VenueName}"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                    <Label Text="·"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                    <Label Text="{Binding City}"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                    <Label Text="{Binding Country, StringFormat='({0})'}"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                    <Label Text="·"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                    <Label Text="{Binding Date, StringFormat='{0:dd MMM yyyy}'}"
                                           FontSize="13"
                                           TextColor="{StaticResource AppTextMuted}" />
                                </HorizontalStackLayout>

                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
