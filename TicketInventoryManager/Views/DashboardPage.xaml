<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TicketInventoryManager.ViewModels"
             x:DataType="vm:DashboardViewModel"
             x:Class="TicketInventoryManager.Views.DashboardPage"
             BackgroundColor="{StaticResource AppBackground}">

    <ContentPage.Resources>
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="Transparent" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="8,6" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="ChipButton" TargetType="Button">
            <Setter Property="BackgroundColor" Value="{StaticResource AppSurfaceRaised}" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="PointerOver">
                            <VisualState.Setters>
                                <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
        </Style>
        <Style x:Key="StatLabel" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
        </Style>
        <Style x:Key="StatValue" TargetType="Label">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{StaticResource AppTextPrimary}" />
        </Style>
        <Style x:Key="StatValueAccent" TargetType="Label">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="TextColor" Value="{StaticResource AppAccent}" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="Label">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextColor" Value="{StaticResource AppTextMuted}" />
            <Setter Property="CharacterSpacing" Value="2" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <!-- Header -->
            <Grid ColumnDefinitions="*, Auto">
                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label Text="Dashboard"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource AppTextPrimary}" />
                    <Label Text="{Binding Username}"
                           FontSize="13"
                           TextColor="{StaticResource AppTextMuted}" />
                </VerticalStackLayout>
                <HorizontalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                    <Button Text="Inventory"
                            Command="{Binding GoToInventoryCommand}"
                            Style="{StaticResource GhostButton}" />
                    <Button Text="Events"
                            Command="{Binding GoToEventsCommand}"
                            IsVisible="{Binding User.IsAdmin}"
                            Style="{StaticResource GhostButton}" />
                    <Button Text="Logout"
                            Command="{Binding LogoutCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource AppAccent}"
                            FontSize="13"
                            Padding="8,6" />
                </HorizontalStackLayout>
            </Grid>

            <!-- Filters card -->
            <Border BackgroundColor="{StaticResource AppSurface}"
                    Stroke="{StaticResource AppBorder}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 10"
                    Padding="20,16">
                <VerticalStackLayout Spacing="12">

                    <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
                        <Label Grid.Column="0" Text="From" VerticalOptions="Center"
                               TextColor="{StaticResource AppTextMuted}" FontSize="13" Margin="0,0,6,0" />
                        <DatePicker Grid.Column="1" Date="{Binding FromSelector}" />
                        <Label Grid.Column="2" Text="To" VerticalOptions="Center"
                               TextColor="{StaticResource AppTextMuted}" FontSize="13" Margin="12,0,6,0" />
                        <DatePicker Grid.Column="3" Date="{Binding ToSelector}" />
                        <BoxView Grid.Column="4" BackgroundColor="Transparent" />
                        <Button Grid.Column="5" Text="This month" Command="{Binding SelectThisMonthCommand}" Style="{StaticResource ChipButton}" />
                        <Button Grid.Column="6" Text="Last month" Command="{Binding SelectLastMonthCommand}" Style="{StaticResource ChipButton}" Margin="6,0,0,0" />
                        <Button Grid.Column="7" Text="This year" Command="{Binding SelectThisYearCommand}" Style="{StaticResource ChipButton}" Margin="6,0,0,0" />
                    </Grid>

                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Grid.Column="0" Text="Event" VerticalOptions="Center"
                               TextColor="{StaticResource AppTextMuted}" FontSize="13" Margin="0,0,12,0" />
                        <Picker Grid.Column="1"
                                ItemsSource="{Binding Events}"
                                SelectedItem="{Binding SelectedEvent}"
                                ItemDisplayBinding="{Binding DisplayName}"
                                Title="All events" />
                        <Button Grid.Column="2" Text="Clear"
                                Command="{Binding ClearEventCommand}"
                                Style="{StaticResource ChipButton}"
                                Margin="8,0,0,0" />
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <!-- Stats: Buys | Sales -->
            <Grid ColumnDefinitions="*, *" ColumnSpacing="16">

                <!-- Buys -->
                <Border Grid.Column="0"
                        BackgroundColor="{StaticResource AppSurface}"
                        Stroke="{StaticResource AppBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="20">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="BUYS" Style="{StaticResource SectionHeader}" />

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Tickets bought" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TicketsBought}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Unsold tickets" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding UnsoldTickets}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Total spent" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TotalSpent, StringFormat='€{0:N2}'}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Avg ticket price" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding AverageTicketBuyPrice, StringFormat='€{0:N2}'}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1">
                            <Label Text="Unsold retail value" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TotalUnsoldRetailValue, StringFormat='€{0:N2}'}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                    </VerticalStackLayout>
                </Border>

                <!-- Sales -->
                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource AppSurface}"
                        Stroke="{StaticResource AppBorder}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 10"
                        Padding="20">
                    <VerticalStackLayout Spacing="0">

                        <Label Text="SALES" Style="{StaticResource SectionHeader}" />

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Tickets sold" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TicketsSold}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Total revenue" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TotalRevenue, StringFormat='€{0:N2}'}" Style="{StaticResource StatValue}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,16">
                            <Label Text="Total profit" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TotalProfit, StringFormat='€{0:N2}'}" Style="{StaticResource StatValueAccent}" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="1" Margin="0,0,0,20">
                            <Label Text="Total ROI" Style="{StaticResource StatLabel}" />
                            <Label Text="{Binding TotalRoi, StringFormat='{0:N2}%'}" Style="{StaticResource StatValueAccent}" />
                        </VerticalStackLayout>

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{StaticResource AppBorder}"
                                 Margin="0,0,0,20" />

                        <Label Text="{Binding BestEvent.Name, TargetNullValue='—'}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource AppTextPrimary}"
                               Margin="0,0,0,4" />
                        <Label Text="best event"
                               Style="{StaticResource StatLabel}"
                               Margin="0,0,0,16" />

                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12">
                            <VerticalStackLayout Grid.Column="0" Spacing="1">
                                <Label Text="Best profit" Style="{StaticResource StatLabel}" />
                                <Label Text="{Binding BestProfit, StringFormat='€{0:N2}'}" Style="{StaticResource StatValueAccent}" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="1">
                                <Label Text="Best ROI" Style="{StaticResource StatLabel}" />
                                <Label Text="{Binding BestRoi, StringFormat='{0:N2}%'}" Style="{StaticResource StatValueAccent}" />
                            </VerticalStackLayout>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
