<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:TicketInventoryManager.ViewModels"
             x:DataType="vm:InventoryLogDetailsViewModel"
             x:Class="TicketInventoryManager.Views.InventoryLogDetailsPage"
             Title="Log Details">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="16">

            <!-- Event -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Event" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding Events}"
                        SelectedItem="{Binding SelectedEvent}"
                        ItemDisplayBinding="{Binding DisplayName}"
                        Title="Select an event" />
            </VerticalStackLayout>

            <!-- Buy info -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Buy Info" FontAttributes="Bold" />

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Buy date:" VerticalOptions="Center" />
                    <DatePicker Date="{Binding BuyDate}" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Sector:" VerticalOptions="Center" />
                    <Entry Text="{Binding Sector}" Placeholder="e.g. Floor, Block A" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Quantity:" VerticalOptions="Center" />
                    <Entry Text="{Binding Quantity}" Keyboard="Numeric" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Buy price per ticket:" VerticalOptions="Center" />
                    <Entry Text="{Binding BuyPerOne}" Keyboard="Numeric" Placeholder="€" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Buy platform:" VerticalOptions="Center" />
                    <Entry Text="{Binding BuyPlatform}" Placeholder="e.g. Ticketmaster" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Account email:" VerticalOptions="Center" />
                    <Entry Text="{Binding AccountEmail}" Keyboard="Email" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Status -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Status" FontAttributes="Bold" />
                <Picker ItemsSource="{Binding Statuses}"
                        SelectedItem="{Binding Status}" />
            </VerticalStackLayout>

            <!-- Sold toggle -->
            <HorizontalStackLayout Spacing="8">
                <Label Text="Sold" VerticalOptions="Center" />
                <Switch IsToggled="{Binding IsSold}" />
            </HorizontalStackLayout>

            <!-- Sell info — visible only when sold -->
            <VerticalStackLayout Spacing="4" IsVisible="{Binding IsSold}">
                <Label Text="Sell Info" FontAttributes="Bold" />

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Sell date:" VerticalOptions="Center" />
                    <DatePicker Date="{Binding SellDate}" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Sell price per ticket:" VerticalOptions="Center" />
                    <Entry Text="{Binding SellPerOne, Mode=TwoWay}" Keyboard="Numeric" Placeholder="€" />
                </HorizontalStackLayout>

                <HorizontalStackLayout Spacing="8">
                    <Label Text="Sell platform:" VerticalOptions="Center" />
                    <Entry Text="{Binding SellPlatform}" Placeholder="e.g. Viagogo" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <!-- Actions -->
            <Button Text="Save" Command="{Binding SaveCommand}" />
            <Button Text="Delete" Command="{Binding DeleteCommand}"
                    IsVisible="{Binding IsExistingLog}" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
